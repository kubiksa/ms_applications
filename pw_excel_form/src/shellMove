Add-Type -AssemblyName System.Windows.Forms
$rng = New-Object System.Random
while ($true) {
    $pos = [System.Windows.Forms.Cursor]::Position
    $moveX = $rng.Next(-3, 3)
    $moveY = $rng.Next(-3, 3)
    [System.Windows.Forms.Cursor]::Position = New-Object System.Drawing.Point(($pos.X + $moveX), ($pos.Y + $moveY))
    Start-Sleep -Seconds $rng.Next(45, 90)
    [System.Windows.Forms.Cursor]::Position = $pos
}
